# ── Datenbank (von Neon.tech kopieren) ─────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── NextAuth ────────────────────────────────────────────────────────────────
# Generiere einen zufälligen Secret: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="dein-geheimer-schluessel-hier"

# Beim lokalen Entwickeln:
NEXTAUTH_URL="http://localhost:3000"
# Auf Vercel: NEXTAUTH_URL wird automatisch gesetzt (nicht nötig)
